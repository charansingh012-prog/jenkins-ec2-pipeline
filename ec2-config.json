terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 1.14.9"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# Security Group
resource "aws_security_group" "launch-wizard-16" {
  name        = "${var.instance_name}-sg"
  description = "Security group for EC2 instance"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.instance_name}-sg"
  }
}

# EC2 Instance
resource "aws_instance" "ec2" {
  ami                    = var.ami-05d2d839d4f73aafb
  instance_type          = var.t2.micro
  key_name               = var.pipelineec2
  vpc_security_group_ids = [subnet-01128435549a14c6d]

  tags = {
    Name        = var.instance_name
    Environment = var.staging
    ManagedBy   = "Terraform+Jenkins"
  }
}
