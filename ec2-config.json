{
  
  "Description": "Create a simple EC2 instance",

  "Resources": {
    "MyEC2Instance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "ImageId": "ami-05d2d839d4f73aafb",
        "InstanceType": "t2.micro",
        "KeyName": "CICDEC2",
        "SecurityGroups": [
          "default"
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "Jenkins-EC2"
          }
        ]
      }
    }
  }
}
